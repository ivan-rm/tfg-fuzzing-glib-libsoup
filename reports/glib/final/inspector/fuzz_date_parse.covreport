  539|       |  /* What we actually do is: multiply years * 365 days in the year,
  540|       |   * add the number of years divided by 4, subtract the number of
  541|       |   * years divided by 100 and add the number of years divided by 400,
  542|       |   * which accounts for leap year stuff. Code from Steffen Beyer's
  543|       |   * DateCalc. 
  544|       |   */
  545|       |  
  546|     13|  year = d->year - 1; /* we know d->year > 0 since it's valid */
  547|       |  
  548|     13|  d->julian_days = year * 365U;
  549|     13|  d->julian_days += (year >>= 2); /* divide by 4 and add */
  550|     13|  d->julian_days -= (year /= 25); /* divides original # years by 100 */
  551|     13|  d->julian_days += year >> 2;    /* divides by 4, which divides original by 400 */
  552|       |  
  553|     13|  idx = g_date_is_leap_year (d->year) ? 1 : 0;
