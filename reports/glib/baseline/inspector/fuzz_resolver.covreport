  532|       |   *   item_start = ((prev_end + a) & b) | c;
  533|       |   */
  534|       |
  535|     15|  item->i = i;
  536|     15|  item->a = a + b;
  537|     15|  item->b = ~b;
  538|     15|  item->c = c;
  539|     15|}
